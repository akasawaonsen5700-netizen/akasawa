{
  "name": "akasawa-integrated-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "node build.js",
    "build-video": "npm run build-video --workspace=apps/endo-sns",
    "install-all": "npm install",
    "dev:sns": "npm run dev --workspace=apps/akasawa-sns",
    "dev:endo": "node pre-dev.js && netlify dev --port=8891 --staticServerPort=3996 --filter=endo-sns-personal-tool",
    "dev:dp": "npm run dev --workspace=apps/akasawa.dp",
    "dev:crm": "npm run dev --workspace=apps/akasawa-ml",
    "dev:chat": "npm run dev --workspace=apps/akasawa-chat",
    "dev:review": "netlify dev --port=8895 --staticServerPort=3995 --filter=akasawa-review -d apps/akasawa-review/public",
    "dev:blog": "npm run dev --workspace=apps/akasawa-blog",
    "dev:ota": "npm run dev --workspace=apps/akasawa-ota"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@remotion/lambda-client": "^4.0.120",
    "dayjs": "^1.11.13",
    "firebase": "^11.10.0",
    "firebase-admin": "^12.6.0",
    "formidable": "^3.5.1",
    "googleapis": "^144.0.0",
    "node-fetch": "^3.3.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.120",
    "@remotion/lambda": "^4.0.120",
    "@remotion/renderer": "^4.0.120",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cheerio": "^1.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.120"
  }
}
